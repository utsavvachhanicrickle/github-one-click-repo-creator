# Node.js Express server listening port
PORT=4000

# App Base URLs (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# MongoDB database connection URI
MONGODB_URI=mongodb://127.0.0.1:27017/github-repo-creator

# express-session encryption key (change this to a secure random string)
SESSION_SECRET=githubautomation123

# GitHub OAuth credentials
# Obtain these from: GitHub > Settings > Developer settings > OAuth Apps (or GitHub Apps)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Permissions requested from the user.
# 'repo' is required to create private repos.
# 'public_repo' can be used if you only want to create public repos.
GITHUB_OAUTH_SCOPES=repo read:user user:email

# App Config
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
SESSION_SECRET=your_express_session_secret_here
BCRYPT=12

# JWT Config
JWT_SECRET=your_jwt_access_secret_key_here
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_key_here

# Email / SMTP Credentials (Used for verification OTPs)
EMAIL_ID=your_email_address_here
EMAIL_SCRETE=your_email_smtp_app_password_here

# Optional: SMTP Configuration (Falls back to EMAIL_ID / EMAIL_SCRETE if not specified)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# PostgreSQL Database Connection URL
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
